generator client {
  provider   = "prisma-client-js"
  /// Use the Rust query-engine binary so local `postgresql://` URLs work.
  /// Avoid `prisma generate --no-engine`; that targets Accelerate/Data Proxy (`prisma://` URLs).
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BROKER
  BUYER
  SELLER
  NRI
  HNI
  BUILDER
  INSTITUTIONAL_SELLER
  INSTITUTIONAL_BUYER
  ADMIN
}

enum OrgRole {
  ADMIN
  AGENT
  VIEWER
}

enum OrganizationInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  PLOT
  INSTITUTIONAL
}

enum DealType {
  SALE
  RENT
}

enum LeadStatus {
  HOT
  WARM
  COLD
  CONVERTED
  LOST
}

enum Urgency {
  IMMEDIATE
  WITHIN_30_DAYS
  FLEXIBLE
}

enum MatchStatus {
  ACTIVE
  VIEWED
  ACCEPTED
  REJECTED
}

enum DealStage {
  LEAD
  REQUIREMENT
  MATCH
  SITE_VISIT
  NEGOTIATION
  LEGAL
  LOAN
  INSURANCE
  PAYMENT
  CLOSURE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PaymentType {
  SUBSCRIPTION
  TOKEN
  FEE
}

enum PaymentStatus {
  CREATED
  CAPTURED
  FAILED
  REFUNDED
}

enum InvoiceType {
  SUBSCRIPTION
  PLATFORM_FEE
  TOKEN
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum EscrowStatus {
  INITIATED
  HELD
  PENDING_PAYOUT
  RELEASED
  REFUNDED
  DISPUTED
  FROZEN
}

enum EscrowTransactionType {
  HOLD
  RELEASE
  REFUND
  FREEZE
}

enum ChatThreadType {
  DEAL
  DIRECT
  SUPPORT
}

enum ChatMessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum ComplianceAlertType {
  MISSING_NDA
  MISSING_RERA
}

enum ComplianceAlertSeverity {
  HIGH
  MEDIUM
  LOW
}

enum ComplianceAlertStatus {
  OPEN
  RESOLVED
}

enum DdCaseStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum DdItemStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum DdEventType {
  CASE_CREATED
  CASE_STATUS_CHANGED
  ITEMS_SYNCED
  ITEM_ASSIGNED
  ITEM_STATUS_CHANGED
  EVIDENCE_ADDED
  NOTE_ADDED
}

model User {
  id         String   @id @default(cuid())
  phoneHash  String   @unique
  phoneEnc   String?
  email      String?
  name       String?
  role       UserRole @default(BUYER)
  trustScore Float    @default(0)
  verified   Boolean  @default(false)
  notificationPrefs   Json?
  onboardingStep      String?
  activeOrganizationId String?
  serviceAreas        String[] @default([])
  reraId              String?
  reputationScore     Float    @default(0)
  razorpayCustomerId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organizationMembers OrganizationMember[]
  activeOrganization  Organization?       @relation("ActiveOrganization", fields: [activeOrganizationId], references: [id], onDelete: SetNull)
  savedSearches       SavedSearch[]
  properties          Property[]
  requirements        Requirement[]
  leadsOwned          Lead[]               @relation("LeadOwner")
  leadNotes           LeadNote[]
  leadFollowUps       LeadFollowUp[]
  dealOffers          DealOffer[]
  serviceRequestsCreated ServiceRequest[] @relation("ServiceRequestCreatedBy")
  institutionsPosted  Institution[]
  ndas                Nda[]
  ndaReviews          Nda[]               @relation("NdaReviewedBy")
  activityLogs        ActivityLog[]
  notifications       Notification[]
  documentsUploaded   Document[]
  reviewsGiven        Review[]             @relation("ReviewAuthor")
  reviewsReceived     Review[]             @relation("ReviewTarget")
  nriProfile          NriProfile?
  hniProfile          HniProfile?
  investorPreference InvestorPreference?
  subscriptions       Subscription[]
  payments            Payment[]
  invoices            Invoice[]
  escrowHeld          EscrowAccount[]      @relation("EscrowHolder")
  escrowBeneficiary   EscrowAccount[]      @relation("EscrowBeneficiary")
  escrowBroker        EscrowAccount[]      @relation("EscrowBroker")
  escrowTxFrom        EscrowTransaction[] @relation("EscrowTxFrom")
  escrowTxTo          EscrowTransaction[] @relation("EscrowTxTo")
  apiKeys             ApiKey[]
  builderProjects     BuilderProject[]    @relation("BuilderProjectOwner")
  projectBookings     ProjectBooking[]    @relation("ProjectBookingBuyer")
  organizationInvitesCreated OrganizationInvite[] @relation("InviteCreatedBy")
  complianceAlertsResolved  ComplianceAlert[]     @relation("ComplianceAlertResolvedBy")
  ddCasesOwned              DueDiligenceCase[]    @relation("DdCaseOwner")
  ddItemsAssigned           DueDiligenceItem[]    @relation("DdItemAssignee")
  ddEvidenceUploaded        DueDiligenceEvidence[]
  ddEventsAuthored          DueDiligenceEvent[]
}

model Organization {
  id         String   @id @default(cuid())
  name       String
  reraNumber String?
  gstNumber  String?
  createdAt  DateTime @default(now())

  members    OrganizationMember[]
  invites          OrganizationInvite[]
  activeUsers      User[]               @relation("ActiveOrganization")
  leads           Lead[]
  deals           Deal[]
  properties      Property[]
  serviceRequests    ServiceRequest[]
  complianceAlerts   ComplianceAlert[]
  dueDiligenceCases  DueDiligenceCase[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model OrganizationInvite {
  id             String                   @id @default(cuid())
  organizationId String
  createdById    String
  code           String                   @unique
  token          String                   @unique
  role           OrgRole                  @default(AGENT)
  status         OrganizationInviteStatus @default(PENDING)
  maxUses        Int                      @default(1)
  usedCount      Int                      @default(0)
  expiresAt      DateTime
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
}

model Property {
  id               String       @id @default(cuid())
  organizationId   String?
  postedById       String
  title            String
  description      String?
  propertyType     PropertyType
  dealType         DealType
  price            Decimal      @db.Decimal(18, 2)
  areaSqft         Float
  city             String
  areaPublic       String
  localityPublic   String
  addressPrivate   String
  latitude         Float
  longitude        Float
  location         Json?
  trustScore       Float        @default(0)
  status           String       @default("active")
  distressedLabel  String       @default("standard")
  isBankAuction    Boolean      @default(false)
  source           String?
  sourceUrl        String?
  sourceId         String?
  listingHash      String?      @unique
  isCrawled        Boolean      @default(false)
  imageUrls        String[]     @default([])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  postedBy     User          @relation(fields: [postedById], references: [id])
  matches      Match[]
  deals        Deal[]
  reviews      Review[]
}

model Requirement {
  id           String       @id @default(cuid())
  userId       String
  budgetMin    Decimal      @db.Decimal(18, 2)
  budgetMax    Decimal      @db.Decimal(18, 2)
  city         String
  areas        String[]
  location     Json?
  propertyType PropertyType
  dealType     DealType
  areaSqftMin  Float
  areaSqftMax  Float
  urgency      Urgency
  tag          String       @default("WARM")
  /// APP | whatsapp_auto | …
  source       String       @default("APP")
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  matches Match[]
  deals   Deal[]
}

model Match {
  id               String      @id @default(cuid())
  propertyId       String
  requirementId    String
  /// Combined ML + rule score (same as matchScore when ML unavailable)
  matchScore       Float
  matchFactors     Json
  status             MatchStatus @default(ACTIVE)
  hotMatch           Boolean     @default(false)
  mlScore            Float?
  combinedScore      Float?
  mlConfidence       Float?
  mlExplanation      Json?
  feedbackGiven      Boolean     @default(false)
  accepted           Boolean?
  convertedToLead    Boolean     @default(false)
  convertedToDeal    Boolean     @default(false)
  createdAt          DateTime    @default(now())

  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([propertyId, requirementId])
}

model Deal {
  id               String    @id @default(cuid())
  organizationId   String
  propertyId       String?
  institutionId    String?
  requirementId    String
  stage            DealStage
  valueInr         Decimal?  @db.Decimal(18, 2)
  slaBreachCount   Int       @default(0)
  dealHealthScore  Float?    @default(50)
  stageEnteredAt   DateTime  @default(now())
  institutionalStage Int?
  coBrokerInviteEmail String?
  commissionSplitPct  Float?
  stageTasks        Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property?    @relation(fields: [propertyId], references: [id])
  institution  Institution? @relation(fields: [institutionId], references: [id])
  requirement  Requirement  @relation(fields: [requirementId], references: [id])
  documents    Document[]
  serviceReqs  ServiceRequest[]
  payments       Payment[]
  escrowAccount  EscrowAccount?
  invoices       Invoice[]
  chatThread     ChatThread?
  offers         DealOffer[]
  complianceAlerts ComplianceAlert[]
  dueDiligenceCases DueDiligenceCase[]
}

model ComplianceAlert {
  id               String                 @id @default(cuid())
  dealId           String
  organizationId   String
  type             ComplianceAlertType
  severity         ComplianceAlertSeverity
  status           ComplianceAlertStatus  @default(OPEN)
  title            String
  body             String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  resolvedAt       DateTime?
  resolvedByUserId String?

  deal         Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resolvedBy   User?        @relation("ComplianceAlertResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@unique([dealId, type])
  @@index([organizationId, status])
  @@index([dealId])
}

model DealOffer {
  id         String   @id @default(cuid())
  dealId      String
  offeredById String
  amountInr   Decimal  @db.Decimal(18, 2)
  notes       String?
  createdAt   DateTime @default(now())

  deal      Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  offeredBy User @relation(fields: [offeredById], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
}

model ChatThread {
  id             String         @id @default(cuid())
  dealId         String?        @unique
  threadType     ChatThreadType @default(DEAL)
  participants   String[]
  title          String?
  lastMessageAt  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  deal     Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([lastMessageAt])
}

model ChatMessage {
  id          String          @id @default(cuid())
  threadId    String
  senderId    String
  content     String          @default("")
  messageType ChatMessageType @default(TEXT)
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  readBy      String[]        @default([])
  editedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Subscription {
  id                       String              @id @default(cuid())
  userId                   String
  planName                 String
  status                   SubscriptionStatus
  razorpaySubscriptionId   String?
  currentPeriodStart       DateTime
  currentPeriodEnd         DateTime
  amountPaise              Int
  interval                 BillingInterval
  cancelledAt              DateTime?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id                 String        @id @default(cuid())
  userId             String
  type               PaymentType
  amountPaise        Int
  status             PaymentStatus @default(CREATED)
  razorpayOrderId    String?       @unique
  razorpayPaymentId  String?
  razorpaySignature  String?
  dealId             String?
  subscriptionId     String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal         Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoices     Invoice[]
}

model Invoice {
  id          String        @id @default(cuid())
  userId      String
  type        InvoiceType
  amountPaise Int
  status      InvoiceStatus
  dueDate     DateTime?
  paidAt      DateTime?
  lineItems   Json
  paymentId   String?
  dealId      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
}

model EscrowAccount {
  id                String       @id @default(cuid())
  dealId            String       @unique
  amountPaise       Int
  currency          String       @default("INR")
  status            EscrowStatus @default(INITIATED)
  holderId          String
  beneficiaryId     String
  brokerId          String?
  razorpayOrderId   String?      @unique
  razorpayPaymentId String?
  heldAt            DateTime?
  releasedAt        DateTime?
  refundedAt        DateTime?
  frozenAt          DateTime?
  pendingPayoutAt   DateTime?
  payoutReference   String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  deal          Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  holder        User                  @relation("EscrowHolder", fields: [holderId], references: [id])
  beneficiary   User                  @relation("EscrowBeneficiary", fields: [beneficiaryId], references: [id])
  broker        User?                 @relation("EscrowBroker", fields: [brokerId], references: [id])
  transactions  EscrowTransaction[]
}

model EscrowTransaction {
  id              String                 @id @default(cuid())
  escrowAccountId String
  type            EscrowTransactionType
  amountPaise     Int
  fromUserId      String?
  toUserId        String?
  razorpayId      String?
  notes           String?
  createdAt       DateTime               @default(now())

  escrow   EscrowAccount @relation(fields: [escrowAccountId], references: [id], onDelete: Cascade)
  fromUser User?         @relation("EscrowTxFrom", fields: [fromUserId], references: [id])
  toUser   User?         @relation("EscrowTxTo", fields: [toUserId], references: [id])
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  ownerId        String
  leadName       String
  phoneEnc       String?
  source         String
  status         LeadStatus
  pipelineStage  String?
  /// CRM tag e.g. SELLER_INQUIRY, INSTITUTIONAL (WhatsApp NLP routing)
  tag            String?
  propertyId     String?
  institutionId  String?
  requirementId  String?
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  owner        User         @relation("LeadOwner", fields: [ownerId], references: [id])
  notes        LeadNote[]
  followUps    LeadFollowUp[]
}

model LeadNote {
  id         String   @id @default(cuid())
  leadId      String
  userId      String
  body        String
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeadFollowUp {
  id           String   @id @default(cuid())
  leadId        String
  userId        String
  dueAt         DateTime
  note          String?
  completed     Boolean  @default(false)
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Institution {
  id                   String   @id @default(cuid())
  postedById           String
  institutionName      String
  institutionType      String
  city                 String
  maskedSummary        String?
  askingPriceCr        Decimal  @db.Decimal(18, 4)
  studentEnrollment    Int?
  latitude             Float
  longitude            Float
  confidential         Boolean  @default(true)
  ndaRequired          Boolean  @default(true)
  verificationStatus   String   @default("unverified")
  dealScore            Float    @default(0)
  createdAt            DateTime @default(now())

  postedBy  User       @relation(fields: [postedById], references: [id])
  ndas      Nda[]
  deals     Deal[]
  documents Document[]
  dueDiligenceCases DueDiligenceCase[]
}

model Nda {
  id            String    @id @default(cuid())
  userId        String
  institutionId String
  status        String
  purpose       String?
  budgetMin     Float?
  budgetMax     Float?
  organizationName String?
  requestedAt   DateTime?
  signedAt      DateTime?
  ipAddress     String?
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?

  user        User        @relation(fields: [userId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])
  reviewedBy  User?       @relation("NdaReviewedBy", fields: [reviewedById], references: [id])

  @@unique([userId, institutionId])
}

model Document {
  id              String   @id @default(cuid())
  dealId          String?
  institutionId   String?
  type            String
  storageKey      String
  uploadedById    String
  version         Int      @default(1)
  accessLevel     String
  downloadAllowed Boolean  @default(false)
  createdAt       DateTime @default(now())

  deal        Deal?        @relation(fields: [dealId], references: [id])
  institution Institution? @relation(fields: [institutionId], references: [id])
  uploadedBy  User         @relation(fields: [uploadedById], references: [id])
  ddEvidence  DueDiligenceEvidence[]
}

model DueDiligenceCase {
  id            String      @id @default(cuid())
  dealId         String?
  institutionId  String?
  organizationId String?
  status         DdCaseStatus @default(OPEN)
  ownerUserId    String?
  summary        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  completedAt    DateTime?

  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  institution Institution? @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  owner       User?        @relation("DdCaseOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  items       DueDiligenceItem[]
  events      DueDiligenceEvent[]

  @@unique([dealId])
  @@unique([institutionId])
  @@index([organizationId, status])
}

model DueDiligenceItem {
  id             String      @id @default(cuid())
  caseId          String
  key             String
  label           String
  required        Boolean     @default(true)
  status          DdItemStatus @default(OPEN)
  assigneeUserId  String?
  dueAt           DateTime?
  notes           String?
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  completedAt     DateTime?

  ddCase    DueDiligenceCase     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignee  User?                @relation("DdItemAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  evidence  DueDiligenceEvidence[]
  events    DueDiligenceEvent[]

  @@unique([caseId, key])
  @@index([caseId, status, sortOrder])
}

model DueDiligenceEvidence {
  id               String    @id @default(cuid())
  itemId            String
  documentId        String?
  uploadedByUserId  String
  kind              String
  title             String?
  url               String?
  notes             String?
  createdAt         DateTime @default(now())

  item       DueDiligenceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  document   Document?        @relation(fields: [documentId], references: [id], onDelete: SetNull)
  uploadedBy User             @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
}

model DueDiligenceEvent {
  id         String      @id @default(cuid())
  caseId      String
  itemId      String?
  actorUserId String?
  type        DdEventType
  detail      Json?
  createdAt   DateTime    @default(now())

  ddCase DueDiligenceCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  item   DueDiligenceItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  actor  User?             @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

enum NotificationType {
  MATCH
  NDA
  DEAL
  ALERT
}

model Notification {
  id        String            @id @default(cuid())
  userId    String
  channel   String
  type      NotificationType  @default(ALERT)
  title     String
  body      String
  read      Boolean           @default(false)
  metadata  Json?
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])
  @@index([userId, read, createdAt])
  @@index([userId, type])
}

model Partner {
  id        String   @id @default(cuid())
  type      String
  name      String
  phone     String?
  email     String?
  city      String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  serviceRequests ServiceRequest[]
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ServiceRequest {
  id              String               @id @default(cuid())
  organizationId  String
  dealId          String?
  type            String
  status          ServiceRequestStatus @default(OPEN)
  partnerId       String?
  createdByUserId String?
  /// Audit trail: JSON array of { at, userId, userName?, action, detail?, from?, to?, partnerId?, partnerName? }
  requestHistory  Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  deal         Deal?          @relation(fields: [dealId], references: [id])
  partner      Partner?       @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  createdBy    User?          @relation("ServiceRequestCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([dealId, status])
  @@index([organizationId, createdAt])
}

model NriProfile {
  userId           String  @id
  country          String?
  assignedManager  String?
  serviceNotes     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HniProfile {
  userId        String @id
  ticketMinCr   Float?
  ticketMaxCr   Float?
  preferences   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuctionListing {
  id          String   @id @default(cuid())
  source      String
  title       String
  city        String
  auctionDate DateTime?
  emdAmount   Decimal? @db.Decimal(18, 2)
  startPrice  Decimal? @db.Decimal(18, 2)
  metadata    Json?
  createdAt   DateTime @default(now())
}

model FraudCase {
  id             String   @id @default(cuid())
  subjectUserId  String?
  propertyId     String?
  dealId         String?
  /// open | review | blocked | cleared
  status         String   @default("open")
  score          Float    @default(0)
  reason         String?
  resolvedById   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CrawlerRun {
  id               String   @id @default(cuid())
  source           String
  startedAt        DateTime @default(now())
  completedAt      DateTime?
  listingsFound    Int      @default(0)
  listingsImported Int      @default(0)
  listingsSkipped  Int      @default(0)
  listingsFailed   Int      @default(0)
  errors           Json?
  status           String   @default("RUNNING")
  createdAt        DateTime @default(now())
}

model ApiKey {
  id            String    @id @default(cuid())
  name          String
  keyHash       String    @unique
  keyPrefix     String
  userId        String
  orgId         String?
  plan          String    @default("FREE")
  callsPerDay   Int       @default(100)
  callsPerMonth Int       @default(1000)
  totalCalls    Int       @default(0)
  lastUsedAt    DateTime?
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages ApiUsage[]
}

model ApiUsage {
  id             String   @id @default(cuid())
  apiKeyId       String
  endpoint       String
  method         String
  responseStatus Int
  responseTimeMs Int
  billedAmount   Int      @default(0)
  createdAt      DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
}

model BuilderProject {
  id             String   @id @default(cuid())
  title          String
  description    String?
  builderId      String
  orgId          String?
  city           String
  locality       String?
  reraProjectId  String
  totalUnits     Int      @default(0)
  phases         Json?
  pricePerSqft   Float?
  priceMin       Decimal? @db.Decimal(18, 2)
  priceMax       Decimal? @db.Decimal(18, 2)
  amenities      Json?
  imageUrls      Json?
  possessionDate DateTime?
  status         String   @default("ACTIVE")
  source         String   @default("MANUAL")
  isCrawled      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  builder  User           @relation("BuilderProjectOwner", fields: [builderId], references: [id], onDelete: Cascade)
  units    ProjectUnit[]
  bookings ProjectBooking[]
}

model ProjectUnit {
  id         String   @id @default(cuid())
  projectId  String
  unitType   String
  floor      Int?
  unitNumber String
  areaSqft   Float?
  price      Decimal? @db.Decimal(18, 2)
  status     String   @default("AVAILABLE")
  createdAt  DateTime @default(now())

  project  BuilderProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bookings ProjectBooking[]
}

model ProjectBooking {
  id          String   @id @default(cuid())
  projectId   String
  unitId      String
  buyerId     String
  amount      Decimal? @db.Decimal(18, 2)
  status      String   @default("PENDING")
  notes       String?
  bookedAt    DateTime @default(now())
  confirmedAt DateTime?

  project BuilderProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unit    ProjectUnit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  buyer   User           @relation("ProjectBookingBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
}

model WhatsAppIngest {
  id          String   @id @default(cuid())
  /// Stable id for webhook retries (Meta message id, custom id, or sha256 of body)
  dedupeKey   String?  @unique
  rawPayload  Json
  /// Mapped intent: e.g. inquiry_text, button_reply, interactive_reply, status, unknown
  intent      String?
  leadId      String?
  /// Meta message `type` (text, button, interactive, image, ...)
  messageType String?
  /// WhatsApp ID (digits) from `messages[].from`
  fromWaId    String?
  /// Inbound text used for NLP (snippet)
  messageText String?
  nlpIntent       String?
  nlpConfidence   Float?
  nlpExtracted    Json?
  routingStatus   String?
  routedAt        DateTime?
  createdLeadId       String?
  createdRequirementId String?
  createdAt   DateTime @default(now())
}

/** Module 38 — IRM basics */
model InvestorPreference {
  userId       String   @id
  assetClasses String[] @default([])
  minTicketCr  Float?
  maxTicketCr  Float?
  geography    String[] @default([])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/** Saved property searches (Module 28) */
model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  filters   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id           String   @id @default(cuid())
  reviewerId   String
  targetUserId String
  propertyId   String?
  rating       Int
  comment      String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  reviewer User      @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
  target   User      @relation("ReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
}
