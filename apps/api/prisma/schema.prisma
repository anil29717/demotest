generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BROKER
  BUYER
  SELLER
  NRI
  HNI
  BUILDER
  INSTITUTIONAL_SELLER
  INSTITUTIONAL_BUYER
  ADMIN
}

enum OrgRole {
  ADMIN
  AGENT
  VIEWER
}

enum OrganizationInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  PLOT
  INSTITUTIONAL
}

enum DealType {
  SALE
  RENT
}

enum LeadStatus {
  HOT
  WARM
  COLD
  CONVERTED
  LOST
}

enum Urgency {
  IMMEDIATE
  WITHIN_30_DAYS
  FLEXIBLE
}

enum MatchStatus {
  ACTIVE
  VIEWED
  ACCEPTED
  REJECTED
}

enum DealStage {
  LEAD
  REQUIREMENT
  MATCH
  SITE_VISIT
  NEGOTIATION
  LEGAL
  LOAN
  INSURANCE
  PAYMENT
  CLOSURE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PaymentType {
  SUBSCRIPTION
  TOKEN
  FEE
}

enum PaymentStatus {
  CREATED
  CAPTURED
  FAILED
  REFUNDED
}

enum InvoiceType {
  SUBSCRIPTION
  PLATFORM_FEE
  TOKEN
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum EscrowStatus {
  INITIATED
  HELD
  PENDING_PAYOUT
  RELEASED
  REFUNDED
  DISPUTED
  FROZEN
}

enum EscrowTransactionType {
  HOLD
  RELEASE
  REFUND
  FREEZE
}

enum ChatThreadType {
  DEAL
  DIRECT
  SUPPORT
}

enum ChatMessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

model User {
  id         String   @id @default(cuid())
  phoneHash  String   @unique
  phoneEnc   String?
  email      String?
  name       String?
  role       UserRole @default(BUYER)
  trustScore Float    @default(0)
  verified   Boolean  @default(false)
  notificationPrefs   Json?
  onboardingStep      String?
  activeOrganizationId String?
  serviceAreas        String[] @default([])
  reraId              String?
  reputationScore     Float    @default(0)
  razorpayCustomerId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organizationMembers OrganizationMember[]
  activeOrganization  Organization?       @relation("ActiveOrganization", fields: [activeOrganizationId], references: [id], onDelete: SetNull)
  savedSearches       SavedSearch[]
  properties          Property[]
  requirements        Requirement[]
  leadsOwned          Lead[]               @relation("LeadOwner")
  leadNotes           LeadNote[]
  leadFollowUps       LeadFollowUp[]
  institutionsPosted  Institution[]
  ndas                Nda[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  documentsUploaded   Document[]
  reviewsGiven        Review[]             @relation("ReviewAuthor")
  reviewsReceived     Review[]             @relation("ReviewTarget")
  nriProfile          NriProfile?
  hniProfile          HniProfile?
  investorPreference InvestorPreference?
  subscriptions       Subscription[]
  payments            Payment[]
  invoices            Invoice[]
  escrowHeld          EscrowAccount[]      @relation("EscrowHolder")
  escrowBeneficiary   EscrowAccount[]      @relation("EscrowBeneficiary")
  escrowBroker        EscrowAccount[]      @relation("EscrowBroker")
  escrowTxFrom        EscrowTransaction[] @relation("EscrowTxFrom")
  escrowTxTo          EscrowTransaction[] @relation("EscrowTxTo")
  apiKeys             ApiKey[]
  builderProjects     BuilderProject[]    @relation("BuilderProjectOwner")
  projectBookings     ProjectBooking[]    @relation("ProjectBookingBuyer")
  organizationInvitesCreated OrganizationInvite[] @relation("InviteCreatedBy")
}

model Organization {
  id         String   @id @default(cuid())
  name       String
  reraNumber String?
  gstNumber  String?
  createdAt  DateTime @default(now())

  members    OrganizationMember[]
  invites          OrganizationInvite[]
  activeUsers      User[]               @relation("ActiveOrganization")
  leads           Lead[]
  deals           Deal[]
  properties      Property[]
  serviceRequests ServiceRequest[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model OrganizationInvite {
  id             String                   @id @default(cuid())
  organizationId String
  createdById    String
  code           String                   @unique
  token          String                   @unique
  role           OrgRole                  @default(AGENT)
  status         OrganizationInviteStatus @default(PENDING)
  maxUses        Int                      @default(1)
  usedCount      Int                      @default(0)
  expiresAt      DateTime
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
}

model Property {
  id               String       @id @default(cuid())
  organizationId   String?
  postedById       String
  title            String
  description      String?
  propertyType     PropertyType
  dealType         DealType
  price            Decimal      @db.Decimal(18, 2)
  areaSqft         Float
  city             String
  areaPublic       String
  localityPublic   String
  addressPrivate   String
  latitude         Float
  longitude        Float
  trustScore       Float        @default(0)
  status           String       @default("active")
  distressedLabel  String       @default("standard")
  isBankAuction    Boolean      @default(false)
  source           String?
  sourceUrl        String?
  sourceId         String?
  listingHash      String?      @unique
  isCrawled        Boolean      @default(false)
  imageUrls        String[]     @default([])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  postedBy     User          @relation(fields: [postedById], references: [id])
  matches      Match[]
  deals        Deal[]
  reviews      Review[]
}

model Requirement {
  id           String       @id @default(cuid())
  userId       String
  budgetMin    Decimal      @db.Decimal(18, 2)
  budgetMax    Decimal      @db.Decimal(18, 2)
  city         String
  areas        String[]
  propertyType PropertyType
  dealType     DealType
  areaSqftMin  Float
  areaSqftMax  Float
  urgency      Urgency
  tag          String       @default("WARM")
  /// APP | whatsapp_auto | …
  source       String       @default("APP")
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  matches Match[]
  deals   Deal[]
}

model Match {
  id               String      @id @default(cuid())
  propertyId       String
  requirementId    String
  /// Combined ML + rule score (same as matchScore when ML unavailable)
  matchScore       Float
  matchFactors     Json
  status             MatchStatus @default(ACTIVE)
  hotMatch           Boolean     @default(false)
  mlScore            Float?
  combinedScore      Float?
  mlConfidence       Float?
  mlExplanation      Json?
  feedbackGiven      Boolean     @default(false)
  accepted           Boolean?
  convertedToLead    Boolean     @default(false)
  convertedToDeal    Boolean     @default(false)
  createdAt          DateTime    @default(now())

  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([propertyId, requirementId])
}

model Deal {
  id               String    @id @default(cuid())
  organizationId   String
  propertyId       String?
  institutionId    String?
  requirementId    String
  stage            DealStage
  valueInr         Decimal?  @db.Decimal(18, 2)
  slaBreachCount   Int       @default(0)
  dealHealthScore  Float?    @default(50)
  stageEnteredAt   DateTime  @default(now())
  institutionalStage Int?
  coBrokerInviteEmail String?
  commissionSplitPct  Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property?    @relation(fields: [propertyId], references: [id])
  institution  Institution? @relation(fields: [institutionId], references: [id])
  requirement  Requirement  @relation(fields: [requirementId], references: [id])
  documents    Document[]
  serviceReqs  ServiceRequest[]
  payments       Payment[]
  escrowAccount  EscrowAccount?
  invoices       Invoice[]
  chatThread     ChatThread?
}

model ChatThread {
  id             String         @id @default(cuid())
  dealId         String?        @unique
  threadType     ChatThreadType @default(DEAL)
  participants   String[]
  title          String?
  lastMessageAt  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  deal     Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([lastMessageAt])
}

model ChatMessage {
  id          String          @id @default(cuid())
  threadId    String
  senderId    String
  content     String          @default("")
  messageType ChatMessageType @default(TEXT)
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  readBy      String[]        @default([])
  editedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model Subscription {
  id                       String              @id @default(cuid())
  userId                   String
  planName                 String
  status                   SubscriptionStatus
  razorpaySubscriptionId   String?
  currentPeriodStart       DateTime
  currentPeriodEnd         DateTime
  amountPaise              Int
  interval                 BillingInterval
  cancelledAt              DateTime?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id                 String        @id @default(cuid())
  userId             String
  type               PaymentType
  amountPaise        Int
  status             PaymentStatus @default(CREATED)
  razorpayOrderId    String?       @unique
  razorpayPaymentId  String?
  razorpaySignature  String?
  dealId             String?
  subscriptionId     String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal         Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoices     Invoice[]
}

model Invoice {
  id          String        @id @default(cuid())
  userId      String
  type        InvoiceType
  amountPaise Int
  status      InvoiceStatus
  dueDate     DateTime?
  paidAt      DateTime?
  lineItems   Json
  paymentId   String?
  dealId      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
}

model EscrowAccount {
  id                String       @id @default(cuid())
  dealId            String       @unique
  amountPaise       Int
  currency          String       @default("INR")
  status            EscrowStatus @default(INITIATED)
  holderId          String
  beneficiaryId     String
  brokerId          String?
  razorpayOrderId   String?      @unique
  razorpayPaymentId String?
  heldAt            DateTime?
  releasedAt        DateTime?
  refundedAt        DateTime?
  frozenAt          DateTime?
  pendingPayoutAt   DateTime?
  payoutReference   String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  deal          Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  holder        User                  @relation("EscrowHolder", fields: [holderId], references: [id])
  beneficiary   User                  @relation("EscrowBeneficiary", fields: [beneficiaryId], references: [id])
  broker        User?                 @relation("EscrowBroker", fields: [brokerId], references: [id])
  transactions  EscrowTransaction[]
}

model EscrowTransaction {
  id              String                 @id @default(cuid())
  escrowAccountId String
  type            EscrowTransactionType
  amountPaise     Int
  fromUserId      String?
  toUserId        String?
  razorpayId      String?
  notes           String?
  createdAt       DateTime               @default(now())

  escrow   EscrowAccount @relation(fields: [escrowAccountId], references: [id], onDelete: Cascade)
  fromUser User?         @relation("EscrowTxFrom", fields: [fromUserId], references: [id])
  toUser   User?         @relation("EscrowTxTo", fields: [toUserId], references: [id])
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  ownerId        String
  leadName       String
  phoneEnc       String?
  source         String
  status         LeadStatus
  pipelineStage  String?
  /// CRM tag e.g. SELLER_INQUIRY, INSTITUTIONAL (WhatsApp NLP routing)
  tag            String?
  propertyId     String?
  institutionId  String?
  requirementId  String?
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  owner        User         @relation("LeadOwner", fields: [ownerId], references: [id])
  notes        LeadNote[]
  followUps    LeadFollowUp[]
}

model LeadNote {
  id         String   @id @default(cuid())
  leadId      String
  userId      String
  body        String
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeadFollowUp {
  id           String   @id @default(cuid())
  leadId        String
  userId        String
  dueAt         DateTime
  note          String?
  completed     Boolean  @default(false)
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Institution {
  id                   String   @id @default(cuid())
  postedById           String
  institutionName      String
  institutionType      String
  city                 String
  maskedSummary        String?
  askingPriceCr        Decimal  @db.Decimal(18, 4)
  studentEnrollment    Int?
  latitude             Float
  longitude            Float
  confidential         Boolean  @default(true)
  ndaRequired          Boolean  @default(true)
  verificationStatus   String   @default("unverified")
  dealScore            Float    @default(0)
  createdAt            DateTime @default(now())

  postedBy  User       @relation(fields: [postedById], references: [id])
  ndas      Nda[]
  deals     Deal[]
  documents Document[]
}

model Nda {
  id            String    @id @default(cuid())
  userId        String
  institutionId String
  status        String
  signedAt      DateTime?
  ipAddress     String?

  user        User        @relation(fields: [userId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])

  @@unique([userId, institutionId])
}

model Document {
  id              String   @id @default(cuid())
  dealId          String?
  institutionId   String?
  type            String
  storageKey      String
  uploadedById    String
  version         Int      @default(1)
  accessLevel     String
  downloadAllowed Boolean  @default(false)
  createdAt       DateTime @default(now())

  deal        Deal?        @relation(fields: [dealId], references: [id])
  institution Institution? @relation(fields: [institutionId], references: [id])
  uploadedBy  User         @relation(fields: [uploadedById], references: [id])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  channel   String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Partner {
  id        String   @id @default(cuid())
  type      String
  name      String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ServiceRequest {
  id             String   @id @default(cuid())
  organizationId String
  dealId         String?
  type           String
  status         String   @default("open")
  partnerId      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  deal         Deal?        @relation(fields: [dealId], references: [id])
}

model NriProfile {
  userId           String  @id
  country          String?
  assignedManager  String?
  serviceNotes     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HniProfile {
  userId        String @id
  ticketMinCr   Float?
  ticketMaxCr   Float?
  preferences   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuctionListing {
  id          String   @id @default(cuid())
  source      String
  title       String
  city        String
  auctionDate DateTime?
  emdAmount   Decimal? @db.Decimal(18, 2)
  startPrice  Decimal? @db.Decimal(18, 2)
  metadata    Json?
  createdAt   DateTime @default(now())
}

model FraudCase {
  id             String   @id @default(cuid())
  subjectUserId  String?
  propertyId     String?
  dealId         String?
  /// open | review | blocked | cleared
  status         String   @default("open")
  score          Float    @default(0)
  reason         String?
  resolvedById   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CrawlerRun {
  id               String   @id @default(cuid())
  source           String
  startedAt        DateTime @default(now())
  completedAt      DateTime?
  listingsFound    Int      @default(0)
  listingsImported Int      @default(0)
  listingsSkipped  Int      @default(0)
  listingsFailed   Int      @default(0)
  errors           Json?
  status           String   @default("RUNNING")
  createdAt        DateTime @default(now())
}

model ApiKey {
  id            String    @id @default(cuid())
  name          String
  keyHash       String    @unique
  keyPrefix     String
  userId        String
  orgId         String?
  plan          String    @default("FREE")
  callsPerDay   Int       @default(100)
  callsPerMonth Int       @default(1000)
  totalCalls    Int       @default(0)
  lastUsedAt    DateTime?
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages ApiUsage[]
}

model ApiUsage {
  id             String   @id @default(cuid())
  apiKeyId       String
  endpoint       String
  method         String
  responseStatus Int
  responseTimeMs Int
  billedAmount   Int      @default(0)
  createdAt      DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
}

model BuilderProject {
  id             String   @id @default(cuid())
  title          String
  description    String?
  builderId      String
  orgId          String?
  city           String
  locality       String?
  reraProjectId  String
  totalUnits     Int      @default(0)
  phases         Json?
  pricePerSqft   Float?
  priceMin       Decimal? @db.Decimal(18, 2)
  priceMax       Decimal? @db.Decimal(18, 2)
  amenities      Json?
  imageUrls      Json?
  possessionDate DateTime?
  status         String   @default("ACTIVE")
  source         String   @default("MANUAL")
  isCrawled      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  builder  User           @relation("BuilderProjectOwner", fields: [builderId], references: [id], onDelete: Cascade)
  units    ProjectUnit[]
  bookings ProjectBooking[]
}

model ProjectUnit {
  id         String   @id @default(cuid())
  projectId  String
  unitType   String
  floor      Int?
  unitNumber String
  areaSqft   Float?
  price      Decimal? @db.Decimal(18, 2)
  status     String   @default("AVAILABLE")
  createdAt  DateTime @default(now())

  project  BuilderProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bookings ProjectBooking[]
}

model ProjectBooking {
  id          String   @id @default(cuid())
  projectId   String
  unitId      String
  buyerId     String
  amount      Decimal? @db.Decimal(18, 2)
  status      String   @default("PENDING")
  notes       String?
  bookedAt    DateTime @default(now())
  confirmedAt DateTime?

  project BuilderProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  unit    ProjectUnit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  buyer   User           @relation("ProjectBookingBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
}

model WhatsAppIngest {
  id          String   @id @default(cuid())
  /// Stable id for webhook retries (Meta message id, custom id, or sha256 of body)
  dedupeKey   String?  @unique
  rawPayload  Json
  /// Mapped intent: e.g. inquiry_text, button_reply, interactive_reply, status, unknown
  intent      String?
  leadId      String?
  /// Meta message `type` (text, button, interactive, image, ...)
  messageType String?
  /// WhatsApp ID (digits) from `messages[].from`
  fromWaId    String?
  /// Inbound text used for NLP (snippet)
  messageText String?
  nlpIntent       String?
  nlpConfidence   Float?
  nlpExtracted    Json?
  routingStatus   String?
  routedAt        DateTime?
  createdLeadId       String?
  createdRequirementId String?
  createdAt   DateTime @default(now())
}

/** Module 38 — IRM basics */
model InvestorPreference {
  userId       String   @id
  assetClasses String[] @default([])
  minTicketCr  Float?
  maxTicketCr  Float?
  geography    String[] @default([])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/** Saved property searches (Module 28) */
model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  filters   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id           String   @id @default(cuid())
  reviewerId   String
  targetUserId String
  propertyId   String?
  rating       Int
  comment      String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  reviewer User      @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
  target   User      @relation("ReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
}
