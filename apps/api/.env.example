DATABASE_URL="postgresql://buildwel:buildwel_dev@127.0.0.1:5433/buildwel?schema=public"
JWT_SECRET="change-me-in-production-min-32-chars-long"
JWT_EXPIRES_IN="7d"
REDIS_URL="redis://localhost:6379"
PORT=4000
FRONTEND_URL="http://localhost:3000"
OTP_DEV_MODE="true"
# Set to "true" only in local/dev: POST /auth/dev-login { "role": "BROKER" } issues JWT without OTP
DEMO_LOGIN="false"
# WhatsApp Cloud API webhook: HMAC verification of raw body (requires rawBody in Nest bootstrap)
WHATSAPP_WEBHOOK_SECRET=""
# Meta subscription verification (GET /webhooks/whatsapp?hub.mode=subscribe&...)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
# Outbound Cloud API (digest + session messages). Create in Meta Developer app.
WHATSAPP_CLOUD_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Daily in-app digest cron (09:00 in this IANA zone). WhatsApp send is still TBD.
DIGEST_TZ="Asia/Kolkata"
# Set to "true" to disable the digest cron (e.g. CI or local experiments)
DISABLE_DIGEST_CRON="false"
# Optional: Elasticsearch for property search (Module 28). After setting URL, run POST /search/admin/reindex-properties as ADMIN.
ELASTICSEARCH_URL=""
ELASTICSEARCH_INDEX="properties"
# Optional API key auth for Elastic Cloud
ELASTICSEARCH_API_KEY=""
# Optional JSON array of deal-stage compliance rules (see ComplianceService); invalid JSON is ignored.
COMPLIANCE_RULES_JSON=""
# Optional: route all inbound WhatsApp messages to this org when body has no org CUID hint
WHATSAPP_DEFAULT_ORGANIZATION_ID=""
# Optional: POST JSON on some WhatsApp webhook failures (signature path)
ALERT_WEBHOOK_URL=""
# Feature flags (set "false" to disable)
FEATURE_WHATSAPP_OUTBOUND=""
FEATURE_EMAIL_OUTBOUND=""
# Stripe webhook (Phase 1 stub — requires stripe-signature header when secret set)
STRIPE_WEBHOOK_SECRET=""
# Next.js: set NEXT_PUBLIC_PWA=false to skip service worker registration
# SMTP placeholders for future real email (email stub logs until wired)
SMTP_HOST=""
SMTP_FROM=""
SMTP_USER=""
SMTP_PASS=""
CRAWLER_TRIGGER_URL=""
SENTRY_DSN=""
LOG_LEVEL="info"
